---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/hub.css';
---
<BaseLayout
  title="The Web Foundry — AI Vibe Coding for Local Businesses"
  description="The Web Foundry rebuilds outdated local business websites using AI vibe coding — for free. See what modern web design can do for your community."
>
  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet" />
  </Fragment>

  <!-- ── Navigation ── -->
  <nav class="nav" id="nav">
    <div class="container nav__inner">
      <a href="#" class="nav__logo">
        <span class="nav__logo-db">The Web</span>
        <span class="nav__logo-design">Foundry</span>
      </a>
      <ul class="nav__links">
        <li><a href="#mission" class="nav__link">Mission</a></li>
        <li><a href="#showcase" class="nav__link">Work</a></li>
        <li><a href="#contact" class="nav__cta">Get in Touch</a></li>
      </ul>
      <button class="nav__hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ── Logo Options Review Panel (remove once logo chosen) ── -->
  <section class="logo-options">
    <div class="container">
      <p class="logo-options__heading">Logo Options — Tell me which to keep</p>
      <div class="logo-options__grid">

        <div class="logo-option">
          <div class="logo-a">
            <span class="logo-a__primary">The Web</span>
            <span class="logo-a__secondary">Foundry</span>
          </div>
          <span class="logo-option__tag">Option A</span>
        </div>

        <div class="logo-option">
          <div class="logo-b">
            <span class="logo-b__name">The Web Foundry</span>
            <span class="logo-b__locale">Cincinnati</span>
          </div>
          <span class="logo-option__tag">Option B</span>
        </div>

        <div class="logo-option">
          <div class="logo-c">
            <span class="logo-c__abbr">WF</span>
            <div class="logo-c__divider" aria-hidden="true"></div>
            <span class="logo-c__wordmark">Web<br/>Foundry</span>
          </div>
          <span class="logo-option__tag">Option C</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Hero ── -->
  <section class="hero" id="hero">
    <div class="hero__bg-grid" aria-hidden="true"></div>
    <div class="hero__noise" aria-hidden="true"></div>
    <div class="hero__glow" aria-hidden="true"></div>

    <div class="container hero__inner">
      <div class="hero__eyebrow reveal">
        <span class="hero__eyebrow-dot"></span>
        AI Vibe Coding × Local Business
      </div>

      <h1 class="hero__headline">
        <span class="hero__word" style="animation-delay:0.15s">Beautiful</span>
        <span class="hero__word" style="animation-delay:0.30s">websites.</span>
        <br/>
        <span class="hero__word hero__word--accent" style="animation-delay:0.50s">Zero</span>
        <span class="hero__word" style="animation-delay:0.65s">cost</span>
        <span class="hero__word" style="animation-delay:0.80s">to you.</span>
      </h1>

      <p class="hero__sub reveal reveal-delay-3">
        We volunteer our time and AI tools to completely rebuild tired, outdated local business websites — delivering modern, high-performance experiences that level the playing field.
      </p>

      <div class="hero__actions reveal reveal-delay-4">
        <a href="#showcase" class="btn btn--primary">See the Work</a>
        <a href="#contact" class="btn btn--ghost">Nominate a Business</a>
      </div>

      <div class="hero__scroll-hint reveal reveal-delay-6" aria-hidden="true">
        <div class="hero__scroll-line"></div>
        <span>Scroll</span>
      </div>
    </div>

    <!-- TODO: Replace with client logo marquee once 2-3 real builds are live -->
    <div class="hero__stat-bar">
      <span>Volunteer Built</span>
      <span class="hero__stat-bar__divider" aria-hidden="true"></span>
      <span>AI-Powered</span>
      <span class="hero__stat-bar__divider" aria-hidden="true"></span>
      <span>Always Evolving</span>
    </div>
  </section>

  <!-- ── Mission / Process ── -->
  <section class="mission" id="mission">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Our Mission</span>
        <h2 class="section-title">The web shouldn't be<br/><em>a luxury</em></h2>
        <p class="section-sub">Small businesses are the backbone of every community. We think they deserve a digital presence that says so.</p>
        <p class="section-sub">Technology moves fast. We keep your web presence current so you can focus on what you actually do.</p>
      </div>

      <div class="mission__rule" aria-hidden="true"></div>

      <div class="mission__steps">
        <div class="step-card reveal reveal-delay-1">
          <div class="step-card__number">01</div>
          <h3 class="step-card__title">Nominate</h3>
          <p class="step-card__desc">Know a local business with a website stuck in 2008? Nominate them — or have them reach out directly.</p>
        </div>
        <div class="step-card reveal reveal-delay-2">
          <div class="step-card__number">02</div>
          <h3 class="step-card__title">Design Sprint</h3>
          <p class="step-card__desc">AI vibe coding lets us iterate through concepts at lightning speed — finding the aesthetic that fits.</p>
        </div>
        <div class="step-card reveal reveal-delay-3">
          <div class="step-card__number">03</div>
          <h3 class="step-card__title">Build &amp; Handoff</h3>
          <p class="step-card__desc">We build the full site, test across devices, and hand it over with guidance on keeping it current.</p>
        </div>
        <div class="step-card reveal reveal-delay-4">
          <div class="step-card__number">04</div>
          <h3 class="step-card__title">Community Wins</h3>
          <p class="step-card__desc">More customers, more trust, a stronger local economy. That's the whole point.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Showcase ── -->
  <section class="showcase" id="showcase">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Featured Work</span>
        <h2 class="section-title">See what's possible<br/><em>for your town</em></h2>
        <p class="section-sub">Three businesses. Three completely different aesthetics. All built with AI — all built with intention.</p>
      </div>

      <div class="projects-grid">

        <a href="/showcase/bakery" class="project-card" id="card-bakery" data-theme="bakery">
          <div class="project-card__visual">
            <div class="project-card__mock project-card__mock--bakery">
              <div class="mock-nav"></div>
              <div class="mock-hero">
                <div class="mock-headline"></div>
                <div class="mock-sub"></div>
                <div class="mock-btn"></div>
              </div>
              <div class="mock-cards">
                <div class="mock-card"></div>
                <div class="mock-card"></div>
                <div class="mock-card"></div>
              </div>
            </div>
            <div class="project-card__overlay">
              <span class="project-card__view">View Site →</span>
            </div>
          </div>
          <div class="project-card__info">
            <div class="project-card__tag">Bakery & Café</div>
            <h3 class="project-card__name">Sweet Crumb Bakery</h3>
            <p class="project-card__desc">Warm, artisan aesthetic with floating pastry animations and an online menu experience.</p>
            <div class="project-card__palette">
              <span class="swatch" style="background:#FDF6EC"></span>
              <span class="swatch" style="background:#C9926B"></span>
              <span class="swatch" style="background:#7A9E82"></span>
            </div>
          </div>
        </a>

        <a href="/showcase/plumber" class="project-card" id="card-plumber" data-theme="plumber">
          <div class="project-card__visual">
            <div class="project-card__mock project-card__mock--plumber">
              <div class="mock-nav"></div>
              <div class="mock-hero">
                <div class="mock-headline"></div>
                <div class="mock-sub"></div>
                <div class="mock-btn"></div>
              </div>
              <div class="mock-cards">
                <div class="mock-card"></div>
                <div class="mock-card"></div>
                <div class="mock-card"></div>
              </div>
            </div>
            <div class="project-card__overlay">
              <span class="project-card__view">View Site →</span>
            </div>
          </div>
          <div class="project-card__info">
            <div class="project-card__tag">Home Services</div>
            <h3 class="project-card__name">Peak Flow Plumbing</h3>
            <p class="project-card__desc">Bold, conversion-focused industrial design with animated trust signals and emergency CTA.</p>
            <div class="project-card__palette">
              <span class="swatch" style="background:#1A2744"></span>
              <span class="swatch" style="background:#FF6B2B"></span>
              <span class="swatch" style="background:#F5F5F5"></span>
            </div>
          </div>
        </a>

        <a href="/showcase/salon" class="project-card" id="card-salon" data-theme="salon">
          <div class="project-card__visual">
            <div class="project-card__mock project-card__mock--salon">
              <div class="mock-nav"></div>
              <div class="mock-hero">
                <div class="mock-headline"></div>
                <div class="mock-sub"></div>
                <div class="mock-btn"></div>
              </div>
              <div class="mock-cards">
                <div class="mock-card"></div>
                <div class="mock-card"></div>
                <div class="mock-card"></div>
              </div>
            </div>
            <div class="project-card__overlay">
              <span class="project-card__view">View Site →</span>
            </div>
          </div>
          <div class="project-card__info">
            <div class="project-card__tag">Beauty & Wellness</div>
            <h3 class="project-card__name">Lumière Salon & Spa</h3>
            <p class="project-card__desc">Luxe editorial aesthetic with champagne tones, masonry gallery, and elegant booking flow.</p>
            <div class="project-card__palette">
              <span class="swatch" style="background:#1C1410"></span>
              <span class="swatch" style="background:#E8D5C4"></span>
              <span class="swatch" style="background:#C9A96E"></span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section" id="contact">
    <div class="cta-section__bg" aria-hidden="true"></div>
    <div class="container cta-section__inner">
      <div class="reveal">
        <span class="section-tag section-tag--light">Get Involved</span>
        <h2 class="cta-section__title">Know a business<br/>that deserves better?</h2>
        <p class="cta-section__sub">Let's talk. We're always looking for our next project — and the community to support it.</p>
        <a href="mailto:hello@dbdesign.dev" class="btn btn--cta">
          hello@dbdesign.dev
          <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__logo">
        <span class="nav__logo-db">The Web</span>
        <span class="nav__logo-design">Foundry</span>
      </div>
      <p class="footer__tagline">AI Vibe Coding for the people.</p>
      <p class="footer__copy">© 2026 The Web Foundry — Cincinnati. Built with ❤️ and AI.</p>
    </div>
  </footer>

  <script>
    import '../scripts/main.js';
  </script>
</BaseLayout>
